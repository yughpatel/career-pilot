http://localhost:5173/templates# =============================================================================
# CAREER PILOT - FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
# All variables MUST start with VITE_ to be accessible in the browser.
# =============================================================================


# -----------------------------------------------------------------------------
# BACKEND API
# -----------------------------------------------------------------------------

# Base URL of the backend API server
# Type: string (URL)
# Production example: https://api.example.com
VITE_API_URL=http://localhost:5000

# Base URL including /api prefix - used by some service files directly
# Type: string (URL)
VITE_API_BASE=http://localhost:5000/api


# -----------------------------------------------------------------------------
# FIREBASE - CLIENT SDK
# -----------------------------------------------------------------------------
# All values found in: Firebase Console > Project Settings > Your Apps > SDK setup
# These are safe to expose publicly - they identify your project, not authenticate it

# Firebase Web API Key
# Type: string
VITE_FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Authentication domain
# Type: string
VITE_FIREBASE_AUTH_DOMAIN=xxxxxxxxxxxxxxxx.firebaseapp.com

# Firebase Project ID
# Type: string
VITE_FIREBASE_PROJECT_ID=xxxxxxxxxxxxxxxx

# Firebase Storage bucket
# Type: string
VITE_FIREBASE_STORAGE_BUCKET=xxxxxxxxxxxxxxxx.appspot.com

# Firebase Cloud Messaging sender ID
# Type: string
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000

# Firebase App ID
# Type: string
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Firebase Measurement ID - used for Google Analytics (optional)
# Type: string
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX


# -----------------------------------------------------------------------------
# FILE UPLOAD
# -----------------------------------------------------------------------------

# Maximum allowed resume upload size in megabytes
# Type: number
VITE_MAX_SIZE_MB=5

VITE_ENABLE_PREMIUM_THEMES=false